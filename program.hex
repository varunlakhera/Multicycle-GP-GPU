// TEST 3: Math Edge Cases (Divide by Zero)
51DE // MUL R1, R13, R14
311F // ADD R1, R1, R15  (R1 = Global ID: 0 through 7)

9264 // CONST R2, 100    (Numerator = 100)
6321 // DIV R3, R2, R1   (R3 = 100 / Global ID)

94C8 // CONST R4, 200    (Base Address = 200)
3441 // ADD R4, R4, R1   (Target Address = 200 + Global ID)

8043 // STR R3, [R4]     (Store division result)
FFFF // RET