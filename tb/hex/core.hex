910A         // Addr 00: CONST R1, 10     R1 = 10
9202         // Addr 01: CONST R2, 2      R2 = 2
0000         // Addr 02: NOP              
3312         // Addr 03: ADD R3, R1, R2   R3 = 10 + 2 = 12
4412         // Addr 04: SUB R4, R1, R2   R4 = 10 - 2 = 8
5512         // Addr 05: MUL R5, R1, R2   R5 = 10 * 2 = 20
6612         // Addr 06: DIV R6, R1, R2   R6 = 10 / 2 = 5
9732         // Addr 07: CONST R7, 50     R7 = 50
8075         // Addr 08: STR R5, [R7]     Store R5(20) in R7(50)
7870         // Addr 09: LDR R8, [R7]     Load the data from Memory Address R7(50) into R8
2062         // Addr 0A: CMP R6, R2       Compare R6 (5) to R2 (2). Since 5 > 2, it sets the POSITIVE flag
120E         // Addr 0B: BRNZP P, 0E      Branch if Positive to PC Address 0E
9163         // Addr 0C: CONST R1, 99     Should be skipped by the branch
FFFF         // Addr 0D: RET              Should be skipped by the branch
FFFF         // Addr 0E: RET              Actual Return - Execution should end here
