9102         // Addr 00: CONST R1, 2        (R1 = 2)
20F1         // Addr 01: CMP R15, R1        (compare LOCAL thread id to 2)
1206         // Addr 02: BRNZP P, 06        (if local T_ID > 2, branch to Path B)
920A         // Addr 03: CONST R2, 10       (R2 = 10)
1E08         // Addr 04: BRNZP NZP, 08      (unconditional jump to merge point)
0000         // Addr 05: NOP                (padding)
9264         // Addr 06: CONST R2, 100      (R2 = 100)
0000         // Addr 07: NOP                (padding)
53DE         // Addr 08: MUL R3, R13, R14   (R3 = block_id * threads_per_block)
343F         // Addr 09: ADD R4, R3, R15    (R4 = global_id = block_offset + local_T_ID)
9532         // Addr 0A: CONST R5, 50       (R5 = base address 50)
3654         // Addr 0B: ADD R6, R5, R4     (R6 = 50 + global_id  -> unique per-thread address)
8062         // Addr 0C: STR R6, R2         (global_data_mem[R6] = R2)
FFFF         // Addr 0D: RET
