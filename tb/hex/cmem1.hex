9105 // Addr 00: CONST R1, 5       (Base Multiplier = 5)
52F1 // Addr 01: MUL R2, R15, R1   (R2 = Thread_ID * 5. Values: 0, 5, 10, 15)
9364 // Addr 02: CONST R3, 100     (R3 = 100, Array A Base Address)
343F // Addr 03: ADD R4, R3, R15   (R4 = 100 + Thread_ID. Unique Addr per thread)
8024 // Addr 04: STR R2, [R4]      (STORE #1: Save our generated values to RAM)
7504 // Addr 05: LDR R5, [R4]      (LOAD: Read the values right back out of RAM into R5)
960A // Addr 06: CONST R6, 10      (R6 = 10)
3756 // Addr 07: ADD R7, R5, R6    (R7 = Loaded Data + 10)
9802 // Addr 08: CONST R8, 2       (R8 = 2)
5978 // Addr 09: MUL R9, R7, R8    (R9 = (Loaded Data + 10) * 2)
9A96 // Addr 0A: CONST R10, 150    (R10 = 150. Array B Base Address)
3BAF // Addr 0B: ADD R11, R10, R15 (R11 = 150 + Thread_ID)
809B // Addr 0C: STR R9, [R11]     (STORE #2: Save the final math result to Array B)
FFFF // Addr 0D: RET               (Halt Execution)
